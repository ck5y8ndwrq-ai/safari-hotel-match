generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Country {
  id       Int      @id @default(autoincrement())
  nameZh   String   @map("name_zh")
  nameEn   String   @map("name_en")
  currency String   @default("USD")
  timezone String?

  regions Region[]

  @@map("countries")
}

model Region {
  id                Int      @id @default(autoincrement())
  countryId         Int      @map("country_id")
  nameZh            String   @map("name_zh")
  nameEn            String   @map("name_en")
  type              String   @default("national_park")
  highSeasonStart   String?  @map("high_season_start")
  highSeasonEnd     String?  @map("high_season_end")
  rainySeasonClosed Boolean  @map("rainy_season_closed") @default(false)

  country Country @relation(fields: [countryId], references: [id])
  hotels  Hotel[]

  @@map("regions")
}

model Hotel {
  id                 Int      @id @default(autoincrement())
  regionId           Int      @map("region_id")
  nameZh             String   @map("name_zh")
  nameEn             String   @map("name_en")
  accommodationType  String   @map("accommodation_type")
  starRating         Int?     @map("star_rating")
  guestRating        Decimal? @map("guest_rating") @db.Decimal(3, 2)
  latitude           Decimal? @db.Decimal(10, 7)
  longitude          Decimal? @db.Decimal(10, 7)
  distanceToParkGate Decimal? @map("distance_to_park_gate") @db.Decimal(5, 2)
  nearestAirstrip    String?  @map("nearest_airstrip")
  distanceToAirstrip Decimal? @map("distance_to_airstrip") @db.Decimal(5, 2)
  transferProvided   Boolean  @map("transfer_provided") @default(false)
  hasChineseService  Boolean  @map("has_chinese_service") @default(false)
  hasChineseMenu     Boolean  @map("has_chinese_menu") @default(false)
  hasChineseGuide    Boolean  @map("has_chinese_guide") @default(false)
  totalRooms         Int?     @map("total_rooms")
  descriptionZh      String?  @map("description_zh") @db.Text
  contactPhone       String?  @map("contact_phone")
  status             String   @default("active")
  createdAt          DateTime @map("created_at") @default(now())

  region         Region               @relation(fields: [regionId], references: [id])
  roomTypes      RoomType[]
  seasonalPrices SeasonalPrice[]
  packages       Package[]
  hotelAmenities HotelAmenity[]
  hotelTags      HotelTag[]
  targetSpecies  HotelTargetSpecies[]
  images         HotelImage[]
  bookingItems   BookingItem[]

  @@map("hotels")
}

model RoomType {
  id           Int     @id @default(autoincrement())
  hotelId      Int     @map("hotel_id")
  nameZh       String  @map("name_zh")
  nameEn       String? @map("name_en")
  roomCategory String  @map("room_category")
  maxGuests    Int     @map("max_guests") @default(2)
  bedType      String? @map("bed_type")

  hotel          Hotel           @relation(fields: [hotelId], references: [id])
  seasonalPrices SeasonalPrice[]
  bookingItems   BookingItem[]

  @@map("room_types")
}

model SeasonalPrice {
  id                Int      @id @default(autoincrement())
  hotelId           Int      @map("hotel_id")
  roomTypeId        Int      @map("room_type_id")
  seasonName        String   @map("season_name")
  dateStart         DateTime @map("date_start")
  dateEnd           DateTime @map("date_end")
  priceRoomOnly     Decimal? @map("price_room_only") @db.Decimal(10, 2)
  priceHalfBoard    Decimal? @map("price_half_board") @db.Decimal(10, 2)
  priceFullBoard    Decimal? @map("price_full_board") @db.Decimal(10, 2)
  priceAllInclusive Decimal? @map("price_all_inclusive") @db.Decimal(10, 2)
  currency          String   @default("USD")
  isAvailable       Boolean  @map("is_available") @default(true)

  hotel    Hotel    @relation(fields: [hotelId], references: [id])
  roomType RoomType @relation(fields: [roomTypeId], references: [id])

  @@map("seasonal_prices")
}

model Package {
  id                    Int      @id @default(autoincrement())
  hotelId               Int      @map("hotel_id")
  nameZh                String   @map("name_zh")
  packageType           String   @map("package_type")
  durationDays          Int      @map("duration_days")
  pricePerPerson        Decimal  @map("price_per_person") @db.Decimal(10, 2)
  pricePerPersonPrivate Decimal? @map("price_per_person_private") @db.Decimal(10, 2)
  includedItems         String?  @map("included_items") @db.Text
  excludedItems         String?  @map("excluded_items") @db.Text

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@map("packages")
}

model Amenity {
  id       Int    @id @default(autoincrement())
  code     String @unique
  nameZh   String @map("name_zh")
  category String

  hotels HotelAmenity[]

  @@map("amenities")
}

model HotelAmenity {
  hotelId   Int     @map("hotel_id")
  amenityId Int     @map("amenity_id")
  isFree    Boolean @map("is_free") @default(true)

  hotel   Hotel   @relation(fields: [hotelId], references: [id])
  amenity Amenity @relation(fields: [amenityId], references: [id])

  @@id([hotelId, amenityId])
  @@map("hotel_amenities")
}

model HotelTag {
  id      Int    @id @default(autoincrement())
  hotelId Int    @map("hotel_id")
  tagCode String @map("tag_code")
  weight  Int    @default(3)

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@map("hotel_tags")
}

model HotelTargetSpecies {
  id              Int  @id @default(autoincrement())
  hotelId         Int  @map("hotel_id")
  species         String
  bestSeasonStart Int? @map("best_season_start")
  bestSeasonEnd   Int? @map("best_season_end")

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@map("hotel_target_species")
}

model HotelImage {
  id        Int    @id @default(autoincrement())
  hotelId   Int    @map("hotel_id")
  url       String
  category  String @default("exterior")
  sortOrder Int    @map("sort_order") @default(0)

  hotel Hotel @relation(fields: [hotelId], references: [id])

  @@map("hotel_images")
}

model Customer {
  id            Int      @id @default(autoincrement())
  name          String
  contactPerson String?  @map("contact_person")
  contactPhone  String?  @map("contact_phone")
  level         String   @default("bronze")
  createdAt     DateTime @map("created_at") @default(now())

  preferences CustomerPreference[]
  bookings    Booking[]

  @@map("customers")
}

model CustomerPreference {
  id         Int    @id @default(autoincrement())
  customerId Int    @map("customer_id")
  prefKey    String @map("pref_key")
  prefValue  String @map("pref_value")

  customer Customer @relation(fields: [customerId], references: [id])

  @@map("customer_preferences")
}

model Booking {
  id          Int      @id @default(autoincrement())
  orderNo     String   @unique @map("order_no")
  customerId  Int?     @map("customer_id")
  operatorId  Int?     @map("operator_id")
  status      String   @default("pending")
  totalAmount Decimal  @map("total_amount") @db.Decimal(12, 2)
  currency    String   @default("USD")
  tripPurpose  String?  @map("trip_purpose")
  groupType   String?  @map("group_type")
  totalGuests Int?     @map("total_guests")
  checkIn     DateTime? @map("check_in")
  checkOut    DateTime? @map("check_out")
  remark      String?  @db.Text
  createdAt   DateTime @map("created_at") @default(now())

  customer Customer? @relation(fields: [customerId], references: [id])
  items    BookingItem[]

  @@map("bookings")
}

model BookingItem {
  id         Int      @id @default(autoincrement())
  bookingId  Int      @map("booking_id")
  hotelId    Int      @map("hotel_id")
  roomTypeId Int?     @map("room_type_id")
  seq        Int      @default(1)
  checkIn    DateTime @map("check_in")
  checkOut   DateTime @map("check_out")
  nights     Int
  boardBasis String   @map("board_basis") @default("room_only")
  unitPrice  Decimal  @map("unit_price") @db.Decimal(10, 2)
  quantity   Int      @default(1)
  subtotal   Decimal  @db.Decimal(12, 2)

  booking  Booking  @relation(fields: [bookingId], references: [id])
  hotel    Hotel    @relation(fields: [hotelId], references: [id])
  roomType RoomType? @relation(fields: [roomTypeId], references: [id])

  @@map("booking_items")
}
